# --- Required for Vercel deployment ---

# MongoDB Atlas connection string. Required.
# Without this, every cold start gets a fresh empty in-memory store and
# data created in one request will not be visible in the next.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sprintboard?retryWrites=true&w=majority

# Optional. Comma-separated list of origins allowed to call the API.
# When unset, same-origin requests work fine (Vercel serves API + client
# from the same domain). Only needed if hosting the client elsewhere.
# CORS_ORIGINS=https://example.com,https://staging.example.com
